<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>O.X. Factory</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&family=Kanit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <?!= include('Styles'); ?>
</head>
<body>
<div id="app">

  <!-- ══════════════════════════════════════════
       SCREEN 1: ROLE SELECT (หน้าแรก ไม่ต้องกด PIN)
  ══════════════════════════════════════════ -->
  <div id="scrRole" class="scr active">
    <div class="role-bg"></div>
    <div class="role-wrap">
      <div class="role-brand">
        <div class="role-logo">🏭</div>
        <h1 class="role-title">O.X. Factory</h1>
        <p class="role-sub">ระบบบันทึกการส่งงาน</p>
      </div>
      <p class="role-choose">เลือกบทบาทของคุณ</p>
      <div class="role-cards">

        <!-- บทบาท 1: ช่าง -->
        <div class="role-card role-tailor" onclick="enterTailor()">
          <div class="rc-icon-wrap rc-red">
            <span class="rc-icon">✂️</span>
          </div>
          <div class="rc-text">
            <div class="rc-title">ส่งงานช่าง</div>
            <div class="rc-desc">บันทึกส่งงาน · ประวัติ · ตั้งค่า</div>
          </div>
          <div class="rc-arrow">›</div>
        </div>

        <!-- บทบาท 2: ผู้จัดการ (ต้อง PIN) -->
        <div class="role-card role-manager" onclick="openPinScreen()">
          <div class="rc-icon-wrap rc-blue">
            <span class="rc-icon">📊</span>
          </div>
          <div class="rc-text">
            <div class="rc-title">รายงานสรุปช่าง</div>
            <div class="rc-desc">ผู้จัดการ · ดูรายงาน · รูปภาพ</div>
          </div>
          <div class="rc-lock">🔒</div>
        </div>

      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       SCREEN 2: PIN (สำหรับผู้จัดการ)
  ══════════════════════════════════════════ -->
  <div id="scrPin" class="scr">
    <div class="pin-bg"></div>
    <div class="pin-wrap">
      <button class="pin-back" onclick="backToRole()">‹ กลับ</button>
      <div class="pin-brand">
        <div class="pin-logo-box">📊</div>
        <div class="pin-title">รายงานสรุปช่าง</div>
        <div class="pin-sub">กรอกรหัส PIN ผู้จัดการ</div>
      </div>
      <div class="pin-card">
        <div class="pin-dots">
          <span class="dot" id="d0"></span>
          <span class="dot" id="d1"></span>
          <span class="dot" id="d2"></span>
          <span class="dot" id="d3"></span>
        </div>
        <div class="pin-err" id="pinErr"></div>
        <div class="keypad">
          <button class="key" onclick="pk('1')">1</button>
          <button class="key" onclick="pk('2')">2</button>
          <button class="key" onclick="pk('3')">3</button>
          <button class="key" onclick="pk('4')">4</button>
          <button class="key" onclick="pk('5')">5</button>
          <button class="key" onclick="pk('6')">6</button>
          <button class="key" onclick="pk('7')">7</button>
          <button class="key" onclick="pk('8')">8</button>
          <button class="key" onclick="pk('9')">9</button>
          <button class="key key-sm" onclick="clearPin()">ล้าง</button>
          <button class="key" onclick="pk('0')">0</button>
          <button class="key key-sm" onclick="delPin()">⌫</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       SCREEN 3A: TAILOR APP (ช่าง)
  ══════════════════════════════════════════ -->
  <div id="scrTailor" class="scr">
    <header class="hdr hdr-red">
      <div class="hdr-l">
        <button class="hdr-back-btn" onclick="exitToRole()">‹</button>
        <span class="hdr-logo">✂️</span>
        <div>
          <div class="hdr-name">ส่งงานช่าง</div>
          <div class="hdr-sub2" id="tailorSub">O.X. Factory</div>
        </div>
      </div>
      <div class="hdr-r">
        <button class="hdr-ico-btn" onclick="openSheet()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
        </button>
      </div>
    </header>

    <!-- Tab nav -->
    <div class="tnav">
      <button class="tnav-btn active" onclick="switchTailorTab(this,'ttRecord')">
        <span>📝</span><span class="tnav-lbl">บันทึก</span>
      </button>
      <button class="tnav-btn" onclick="switchTailorTab(this,'ttHistory')">
        <span>📋</span><span class="tnav-lbl">ประวัติ</span>
      </button>
      <button class="tnav-btn" onclick="switchTailorTab(this,'ttSettings')">
        <span>⚙️</span><span class="tnav-lbl">ตั้งค่า</span>
      </button>
    </div>

    <div class="scr-body">

      <!-- TAB: บันทึก -->
      <div id="ttRecord" class="tab active">
        <div class="form-wrap">
          <div class="fsec-title">📝 บันทึกการส่งงาน</div>

          <div class="fg">
            <label class="fl">ชื่อช่าง <span class="req">*</span></label>
            <div class="sel-wrap">
              <select id="techSel" class="fc">
                <option value="">— เลือกช่าง —</option>
              </select>
              <span class="sel-arr">▾</span>
            </div>
          </div>

          <div class="fg">
            <label class="fl">ชื่อรูป / รุ่น</label>
            <input type="text" id="modelName" class="fc" placeholder="เช่น เสื้อเชิ้ต รุ่น A...">
          </div>

          <div class="fg-row">
            <div class="fg">
              <label class="fl">วันที่ <span class="req">*</span></label>
              <input type="date" id="workDate" class="fc" onchange="onDateChg()">
            </div>
            <div class="fg">
              <label class="fl">จำนวนตัว <span class="req">*</span></label>
              <input type="number" id="qty" class="fc fc-num" placeholder="0" min="0" inputmode="numeric">
            </div>
          </div>

          <!-- Week badge -->
          <div class="week-row" id="weekRow">
            <span class="wlabel">รอบจ่าย:</span>
            <span class="wbadge" id="wBadge">—</span>
          </div>

          <div class="fg">
            <label class="fl">หมายเหตุ</label>
            <textarea id="noteInp" class="fc fc-ta" placeholder="(ถ้ามี)"></textarea>
          </div>

          <!-- Image upload -->
          <div class="fg">
            <label class="fl">📷 รูปภาพหลักฐาน <span class="fl-hint">(เลือกได้หลายรูป)</span></label>
            <div class="upzone" onclick="trigUpload()">
              <div class="upz-ico">📸</div>
              <div class="upz-main">แตะเพื่อเลือกรูปภาพ</div>
              <div class="upz-sub">รองรับ iOS &amp; Android · หลายรูปพร้อมกัน</div>
            </div>
            <input type="file" id="imgInp" accept="image/*" multiple style="display:none" onchange="onImgSel(event)">
            <div id="imgPrev" class="img-grid"></div>
          </div>

          <button class="btn-submit" id="btnSubmit" onclick="submitRec()">
            💾 บันทึกการส่งงาน
          </button>
        </div>
      </div>

      <!-- TAB: ประวัติ -->
      <div id="ttHistory" class="tab">
        <div class="fstrip">
          <button class="fs-btn active" onclick="setHF(this,'all')">ทั้งหมด</button>
          <button class="fs-btn" onclick="setHF(this,'Week 1')">Week 1</button>
          <button class="fs-btn" onclick="setHF(this,'Week 2')">Week 2</button>
          <button class="fs-btn" onclick="setHF(this,'Week End')">Week End</button>
        </div>
        <div id="histList" class="clist">
          <div class="empty-st"><span>⏳</span>กำลังโหลด...</div>
        </div>
      </div>

      <!-- TAB: ตั้งค่า -->
      <div id="ttSettings" class="tab">
        <div class="sett-wrap">
          <div class="sett-title">⚙️ จัดการรายชื่อช่าง</div>
          <div class="sett-add">
            <input type="text" id="newTechInp" class="fc" placeholder="ชื่อช่างใหม่...">
            <button class="btn-add" onclick="addTech()">+ เพิ่ม</button>
          </div>
          <div id="techListEl" class="tech-list">
            <div class="empty-st"><span>⏳</span>กำลังโหลด...</div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ══════════════════════════════════════════
       SCREEN 3B: MANAGER APP (ผู้จัดการ)
  ══════════════════════════════════════════ -->
  <div id="scrManager" class="scr">
    <header class="hdr hdr-blue">
      <div class="hdr-l">
        <button class="hdr-back-btn" onclick="exitToRole()">‹</button>
        <span class="hdr-logo">📊</span>
        <div>
          <div class="hdr-name">รายงานสรุปช่าง</div>
          <div class="hdr-sub2">O.X. Factory</div>
        </div>
      </div>
      <div class="hdr-r">
        <button class="hdr-ico-btn" onclick="openSheet()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
        </button>
        <button class="hdr-ico-btn" onclick="exitToRole()" title="ออกจากระบบ">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </header>

    <div class="scr-body">

      <!-- Summary banner -->
      <div class="mgr-banner" id="mgrBanner">
        <div class="mb-loading">กำลังโหลด...</div>
      </div>

      <!-- Filter toolbar -->
      <div class="mgr-toolbar">
        <div class="mgr-search-wrap">
          <span class="mgr-sico">🔍</span>
          <input type="text" id="mgrSearch" class="mgr-sinp" placeholder="ค้นหาชื่อช่าง...">
        </div>
        <div class="mgr-frow">
          <button class="mf-btn active" onclick="setMF(this,'all')">ทั้งหมด</button>
          <button class="mf-btn" onclick="setMF(this,'Week 1')">Week 1</button>
          <button class="mf-btn" onclick="setMF(this,'Week 2')">Week 2</button>
          <button class="mf-btn" onclick="setMF(this,'Week End')">Week End</button>
        </div>
      </div>

      <!-- Report cards -->
      <div id="mgrContent" class="mgr-content">
        <div class="empty-st"><span>⏳</span>กำลังโหลด...</div>
      </div>

    </div>
  </div>

  <!-- ══════════════════════════════════════════
       MODAL (bottom sheet)
  ══════════════════════════════════════════ -->
  <div id="modal" class="modal-bg" onclick="onMBg(event)">
    <div class="modal-sheet">
      <div class="modal-handle"></div>
      <div id="modalBody"></div>
    </div>
  </div>

  <!-- LIGHTBOX -->
  <div id="lb" class="lb" onclick="lbClose()">
    <button class="lb-x" onclick="lbClose()">✕</button>
    <div class="lb-prev" onclick="lbNav(-1,event)">‹</div>
    <img id="lbImg" src="" alt="" onclick="event.stopPropagation()">
    <div class="lb-next" onclick="lbNav(1,event)">›</div>
    <div class="lb-ctr" id="lbCtr"></div>
  </div>

  <!-- TOAST -->
  <div id="toast" class="toast"></div>

  <!-- LOADER -->
  <div id="loader" class="loader-ov">
    <div class="loader-box">
      <div class="loader-ring"></div>
      <div class="loader-txt" id="loaderTxt">กำลังดำเนินการ...</div>
    </div>
  </div>

</div>
<?!= include('Scripts'); ?>
</body>
</html>
